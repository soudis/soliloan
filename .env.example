# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

COMPOSE_PROJECT_NAME=soliloan
DOCKER_IMAGE_TAG=dev
ENVIRONMENT=dev

# Docker Hub image (production compose override), e.g. myuser/soliloan — no registry prefix
# DOCKERHUB_REPOSITORY=myuser/soliloan

# Traefik (Docker Compose app labels in docker/app/compose.base.yml)
# Public hostname for the Host() router rule — must match the domain you open in the browser.
# Local dev: same host as SOLILOAN_URL / NEXTAUTH_URL without scheme, e.g. soliloan.localhost
# Production: usually your public domain (GitHub Actions variable TRAEFIK_HOST; often equals SOLILOAN_DOMAIN)
TRAEFIK_HOST=soliloan.localhost

# Postgres
# https://hub.docker.com/_/postgres/
POSTGRES_DB=soliloan
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_USER=postgres

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}"
NEXTAUTH_SECRET="your_nextauth_secret_key_here"
NEXTAUTH_URL="https://soliloan.localhost"
NEXTAUTH_URL_INTERNAL="http://app:3000"
AUTH_TRUST_HOST=true

SOLILOAN_DOMAIN="your-domain.com"
SOLILOAN_PROJECT_NAME="Your Project Name"
SOLILOAN_URL="https://soliloan.localhost"
SOLILOAN_ADMIN_EMAIL="admin@your-domain.com"
SOLILOAN_ADMIN_PASSWORD="your_admin_password"
SOLILOAN_DEFAULT_LANGUAGE="de"

# Einladungs-Link: Gültigkeit in Tagen (Fallback: 14)
SOLILOAN_INVITE_VALID_DAYS=14

# SMTP Configuration
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
# false for port 587 (STARTTLS); true for port 465 (implicit TLS). Omit to auto-detect from port.
SMTP_SECURE="false"
SMTP_USER="your-email@your-provider.com"
SMTP_PASSWORD="your_smtp_app_password"
SMTP_FROM="your-email@your-provider.com"
