{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: dev (inspect)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "env": {
        "NODE_OPTIONS": "--inspect"
      }
    },
    {
      "name": "Next.js: attach (9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/node_modules/**"]
    },
    {
      "name": "Next.js: Chrome (client)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ],
  "compounds": [
    {
      "name": "Fullstack: Next.js + Chrome",
      "configurations": ["Next.js: dev (inspect)", "Next.js: Chrome (client)"]
    }
  ]
}
