{
  "name": "soliloan-ai",
  "version": "0.1.5",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint",
    "export:templates": "tsx scripts/export-email-templates.ts",
    "export:global-dashboard-layout": "tsx scripts/export-global-dashboard-layout.ts",
    "prisma:generate": "prisma generate",
    "prisma:studio": "bash -c 'source <(grep -E \"^POSTGRES_\" .env) && DATABASE_URL=\"postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}\" prisma studio'",
    "prisma:push": "bash -c 'source <(grep -E \"^POSTGRES_\" .env) && DATABASE_URL=\"postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}\" prisma db push'",
    "prisma:seed": "bash -c 'source <(grep -E \"^POSTGRES_\" .env) && DATABASE_URL=\"postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}\" prisma db seed'",
    "prisma:migrate:dev": "bash -c 'source <(grep -E \"^POSTGRES_\" .env) && DATABASE_URL=\"postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}\" prisma migrate dev'",
    "prisma:migrate:reset": "bash -c 'source <(grep -E \"^POSTGRES_\" .env) && DATABASE_URL=\"postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}\" prisma migrate reset'",
    "format": "biome format src prisma",
    "format:fix": "biome format src prisma --write",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -f docker/app/Dockerfile -t soudis/soliloan:local --build-arg NEXT_PUBLIC_SOLILOAN_PROJECT_NAME=Soliloan --build-arg NEXT_PUBLIC_SOLILOAN_URL=http://localhost:3000 .",
    "docker:dev": "docker compose -f docker/compose.dev.yml --project-directory .",
    "docker:dev:up": "docker compose -f docker/compose.dev.yml --project-directory . up --no-attach mailpit"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@auth/prisma-adapter": "^2.11.2",
    "@craftjs/core": "^0.2.12",
    "@craftjs/layers": "^0.2.7",
